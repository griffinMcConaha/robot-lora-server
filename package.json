{
  "name": "robot-lora-server",
  "version": "0.1.0",
  "private": true,
  "description": "LoRa base-station server for boundary mapping, live coverage, and path planning",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test tests/*.test.js",
    "test:hil": "node --test tests/hil.test.js",
    "ops:phase1": "node scripts/phase1-transport-check.js",
    "release:gate": "node scripts/release-gate.js",
    "ops:key-rotation:check": "node scripts/key-rotation-check.js",
    "ops:sqlite:drill": "node scripts/sqlite-drill.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  }
}
